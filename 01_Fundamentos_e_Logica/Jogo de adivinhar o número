jogar_novamente = True

while jogar_novamente:
    loop = True

    while loop:
        escolha_computador = randint(1, 10)

        print("\nEstou pensando em um número entre 1 e 10. Tente adivinhar!")
        entrada_usuario = input("Escolha um número: ")

        # Valida se é um número
        if not entrada_usuario.isdigit():
            print("Entrada inválida! Digite apenas números.")
            continue

        escolha_usuario = int(entrada_usuario)

        # Valida o intervalo
        if 1 <= escolha_usuario <= 10:
            if escolha_usuario == escolha_computador:
                print("Parabéns! Você acertou!")
                loop = False
            else:
                print(f"Você errou! O número correto era: {escolha_computador}")
        else:
            print("Número inválido! Escolha um número entre 1 e 10.")

    resposta = input("Deseja jogar novamente? (sim/não): ").strip().lower()
    if resposta != "sim":
        jogar_novamente = False

print("Obrigado por jogar!")